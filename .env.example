# =============================================================
# Agent Sentinel — Environment Variable Template
# Copy to .env and fill in values before starting any agent.
# =============================================================

# --- OTel Export (required by every instrumented agent) ---

# Where to push telemetry (points at the local Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc          # grpc | http/protobuf

# Human-readable name that appears as a label in Grafana
OTEL_SERVICE_NAME=my-agent

# Namespace groups related agents (e.g. "research", "coding")
OTEL_SERVICE_NAMESPACE=default

# Semantic version of the agent code
OTEL_SERVICE_VERSION=0.1.0

# Propagate trace context across sub-processes
OTEL_PROPAGATORS=tracecontext,baggage

# --- Agent Sentinel custom dimensions ---

# Which LLM model this agent runs on
AGENT_MODEL=claude-sonnet-4-6

# Max context window tokens (used to compute Context Battery %)
AGENT_CONTEXT_WINDOW=200000

# Arbitrary project tag for cross-project dashboard filtering
AGENT_PROJECT=my-project

# --- Infrastructure (docker-compose only) ---

GRAFANA_ADMIN_PASSWORD=sentinel
